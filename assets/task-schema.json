{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness Loop Tasks",
  "description": "Task DAG for harness-loop orchestration",
  "type": "object",
  "required": ["metadata", "tasks"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["project_name", "created_at", "updated_at", "current_phase"],
      "properties": {
        "project_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "current_phase": {
          "type": "string",
          "enum": ["init", "requirements", "architecture", "uiux", "engineering", "qa", "complete"]
        },
        "telegram_chat_id": { "type": "string" },
        "telegram_bot_token_env": { "type": "string" }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "phase", "status", "dependencies", "acceptance_criteria", "output_files"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(arch|uiux|eng|qa)-\\d+$",
            "description": "Task ID in format {phase_prefix}-{number}"
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "phase": {
            "type": "string",
            "enum": ["architecture", "uiux", "engineering", "qa"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "blocked"]
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Task IDs that must be done before this task can start"
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Verifiable conditions for task completion"
          },
          "output_files": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Files created or modified by this task"
          },
          "retry_count": {
            "type": "integer",
            "minimum": 0,
            "default": 0
          },
          "started_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "completed_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "notes": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
